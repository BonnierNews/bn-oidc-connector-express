{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Read(.env*)",
      "Edit(.env*)",
      "Write(.env*)",
      "Bash(cat .env*)",
      "Bash(cat *.env)",
      "Bash(less .env*)",
      "Bash(more .env*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)"
    ]
  },
  "defaultMode": "dontAsk",
  "systemPrompt": "Always read and follow CLAUDE.md at the beginning of every task, including after context resets. Treat its contents as mandatory project conventions.",
  "enabledPlugins": {
  }
}
